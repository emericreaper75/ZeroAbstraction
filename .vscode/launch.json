{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: Debug Server",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev"
        },
        {
            "name": "Next.js: Debug Client",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Next.js: Full Stack",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "serverReadyAction": {
                "pattern": "http://localhost:\\d+",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        }
    ],
    "compounds": []
}